{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bytemasterwez.github.io/jigsaw/schemas/kernel_v1.schema.json",
  "title": "KernelV1Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "engine_name",
    "subject",
    "summary",
    "classification",
    "score",
    "confidence",
    "rationale",
    "evidence",
    "signals",
    "outputs",
    "provenance"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "kernel.v1"},
    "engine_name": {"type": "string", "minLength": 1},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject_type", "subject_id"],
      "properties": {
        "subject_type": {"type": "string", "minLength": 1},
        "subject_id": {"type": "string", "minLength": 1}
      }
    },
    "summary": {"type": "string", "minLength": 1},
    "classification": {"type": "string", "minLength": 1},
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "rationale": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_type", "source_id", "source_item_id", "snippet", "relevance", "confidence", "observed_at", "provenance"],
        "properties": {
          "evidence_type": {"type": "string", "minLength": 1},
          "source_id": {"type": "string", "minLength": 1},
          "source_item_id": {"type": "string", "minLength": 1},
          "snippet": {"type": "string", "minLength": 1},
          "relevance": {"type": "number", "minimum": 0, "maximum": 1},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "observed_at": {"type": "string", "format": "date-time"},
          "provenance": {"type": "object", "minProperties": 1, "additionalProperties": true}
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relevance", "novelty", "actionability", "recurrence"],
      "properties": {
        "relevance": {"type": "number", "minimum": 0, "maximum": 1},
        "novelty": {"type": "number", "minimum": 0, "maximum": 1},
        "actionability": {"type": "number", "minimum": 0, "maximum": 1},
        "recurrence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true,
      "required": ["matched_targets", "recommended_action", "tags"],
      "properties": {
        "matched_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_id", "label", "strength"],
            "properties": {
              "target_id": {"type": "string", "minLength": 1},
              "label": {"type": "string", "minLength": 1},
              "strength": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        },
        "recommended_action": {"type": "string", "minLength": 1},
        "tags": {"type": "array", "items": {"type": "string"}}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "source_system", "engine_version"],
      "properties": {
        "generated_at": {"type": "string", "format": "date-time"},
        "source_system": {"type": "string", "minLength": 1},
        "engine_version": {"type": "string", "minLength": 1}
      }
    }
  }
}
