{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jigsaw.local/contracts/common/metadata.v1.json",
  "title": "JigsawMetadataV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "object_id",
    "schema_version",
    "created_at",
    "updated_at",
    "source_system",
    "pipeline_run_id",
    "confidence",
    "tags",
    "lineage"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_run_id": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lineage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

