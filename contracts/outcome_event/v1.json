{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jigsaw.local/contracts/outcome_event/v1.json",
  "title": "JigsawOutcomeEventV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "event_id",
    "case_id",
    "action_id",
    "observed_outcome",
    "recorded_by",
    "timestamp",
    "effect_on_confidence",
    "notes"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "const": "outcome_event"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "observed_outcome": {
      "type": "string",
      "enum": [
        "confirmed",
        "strengthened",
        "unchanged",
        "weakened",
        "invalidated"
      ]
    },
    "recorded_by": {
      "type": "string",
      "enum": [
        "human",
        "system",
        "unknown"
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "effect_on_confidence": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
