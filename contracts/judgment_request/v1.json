{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jigsaw.local/contracts/judgment_request/v1.json",
  "title": "JigsawJudgmentRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "request_id",
    "artifact_id",
    "subject",
    "context",
    "chunks",
    "evidence",
    "metadata"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "const": "judgment_request"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "type"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "document",
            "event",
            "signal",
            "record",
            "other"
          ]
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "source_type",
        "analysis_profile"
      ],
      "properties": {
        "source_system": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "analysis_profile": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chunk_id",
          "text",
          "section_label"
        ],
        "properties": {
          "chunk_id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "section_label": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provenance",
        "hash_sha256"
      ],
      "properties": {
        "provenance": {
          "type": "object",
          "additionalProperties": true
        },
        "hash_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "$ref": "../common/metadata.v1.json"
    }
  }
}

