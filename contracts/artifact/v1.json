{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jigsaw.local/contracts/artifact/v1.json",
  "title": "JigsawArtifactV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "artifact_id",
    "source_system",
    "source_type",
    "title",
    "created_at",
    "ingested_at",
    "content_ref",
    "raw_text",
    "mime_type",
    "language",
    "metadata",
    "provenance"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "const": "artifact"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "pdf",
        "image",
        "note",
        "csv",
        "email",
        "json",
        "other"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "content_ref": {
      "type": "string",
      "minLength": 1
    },
    "raw_text": {
      "type": "string",
      "minLength": 1
    },
    "mime_type": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "path",
        "hash_sha256"
      ],
      "properties": {
        "origin": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash_sha256": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

