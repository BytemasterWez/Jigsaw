{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jigsaw.local/contracts/kernel_input/v1.json",
  "title": "JigsawKernelInputV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "input_id",
    "subject_id",
    "subject_type",
    "content",
    "context",
    "evidence",
    "metadata"
  ],
  "properties": {
    "contract": {
      "type": "string",
      "const": "kernel_input"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "input_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_id": {
      "type": "string",
      "minLength": 1
    },
    "subject_type": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "observed_items",
        "expected_items",
        "claims"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "observed_items": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "expected_items": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "claims": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "kind",
          "text",
          "confidence",
          "observed_at",
          "provenance"
        ],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "observed_at": { "type": "string", "format": "date-time" },
          "provenance": {
            "type": "object",
            "additionalProperties": true,
            "minProperties": 1
          }
        }
      }
    },
    "metadata": {
      "$ref": "../common/metadata.v1.json"
    }
  }
}

